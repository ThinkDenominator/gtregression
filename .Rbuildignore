# RStudio and local session files
^\.Rproj$
^gtregression\.Rproj$
^\.Rproj\.user$
^\.Rhistory$
^.*\.Rhistory$
^\.RData$
^.*\.RData$
^\.RDataTmp.*$
^\.DS_Store$
^.*/\.DS_Store$

# Development-only project files
^README\.Rmd$
^README - Rubes\.md$
^LICENSE\.md$
^renv$
^renv\.lock$
^\.github$
^\.zenodo\.json$
^codecov\.yml$
^_pkgdown\.yml$
^pkgdown$
^cran-comments\.md$
^CRAN-SUBMISSION$

# Generated documentation and build metadata
^doc$
^docs$
^Meta$
^index\.md$
^tests/testthat\.Rout\.fail$
^tests/testthat\.Rout$

# Local output artifacts
^Rplots\.pdf$
^tests/testthat/Rplots\.pdf$
^Why_Denominators_Matter.*\.docx$

# Tool/editor metadata
^.*~$
^\.positai$
^\.claude$
